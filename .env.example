# Optional: without a key Alexandria uses its deterministic planner.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Required in production: a random secret (at least 16 characters) used only
# to HMAC client addresses for durable abuse control. Raw addresses are not stored.
RECOVERY_RATE_LIMIT_SECRET=

# Optional stable recovery produced through the ordinary public pipeline.
NEXT_PUBLIC_REFERENCE_RECOVERY_PATH=

# Used only by release-operator commands after deployment.
ALEXANDRIA_BASE_URL=http://localhost:3000
ALEXANDRIA_REFERENCE_URL=
ALEXANDRIA_PROOF_URL=http://iexile.com/
ALEXANDRIA_PROOF_YEAR=2009
