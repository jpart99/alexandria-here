/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Standards-compatible fallback for the physical asset store. Browser-facing
# font aliases are enforced by the application Worker, not inferred here.
/fonts/*.woff2
  Content-Type: font/woff2
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff
