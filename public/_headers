/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Standards-compatible fallback. Sites production MIME is enforced by the
# selective Worker-first ASSETS route, not inferred from this file.
/fonts/*.woff2
  Content-Type: font/woff2
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff
