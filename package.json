{
  "name": "alexandria-here",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "node scripts/start-local-dev.mjs",
    "build": "vinext build",
    "start": "node scripts/start-compiled-preview.mjs",
    "test": "tsx --test tests/*.test.ts",
    "qa:failure-matrix": "node scripts/run-failure-matrix.mjs",
    "qa:release": "npm test && tsc --noEmit && npm run lint && node scripts/release-readiness.mjs",
    "qa:release:compiled": "node scripts/release-readiness.mjs --compiled",
    "qa:production": "node scripts/production-smoke.mjs",
    "qa:submission": "tsx scripts/submission-readiness.ts",
    "qa:media": "tsx scripts/audit-final-media-v23.ts",
    "qa:submission:live": "node scripts/submission-live-proof.mjs",
    "proof:model": "node scripts/prove-model.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern .wrangler",
    "db:generate": "drizzle-kit generate",
    "reference:produce": "node scripts/produce-reference.mjs"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "drizzle-orm": "0.45.2",
    "entities": "7.0.1",
    "next": "^16.2.10",
    "openai": "^6.48.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/workers-types": "^5.20260718.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.28",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.10",
    "react-server-dom-webpack": "^19.2.7",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "type": "module"
}
